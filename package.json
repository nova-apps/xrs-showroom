{
  "name": "xrs-showroom",
  "version": "0.10.0",
  "private": true,
  "engines": {
    "node": "20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:deploy": "playwright test --config playwright.deploy.config.js",
    "lint": "eslint app/ components/ hooks/ lib/ tests/",
    "lint:fix": "eslint app/ components/ hooks/ lib/ tests/ --fix",
    "version:patch": "node scripts/generate-changelog.js --patch",
    "version:minor": "node scripts/generate-changelog.js --minor",
    "version:major": "node scripts/generate-changelog.js --major",
    "predeploy": "node scripts/generate-changelog.js --patch",
    "deploy": "npm test && npm run predeploy && firebase deploy"
  },
  "dependencies": {
    "@sparkjsdev/spark": "^2.0.0",
    "firebase": "^12.11.0",
    "leaflet": "^1.9.4",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.4",
    "typescript": "^6.0.3"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
